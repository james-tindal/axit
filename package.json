{
  "name": "axit",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "stylus stylus/style.styl -o public/css/ --print --sourcemap > public/css/style.css",
    "build:js": "esbuild js/entry.js --bundle --outfile=public/js/all.js --target=es2015 --sourcemap",
    "build": "npm run build:css && npm run build:js",
    "start": "npm i --production & npx http-server"
  },
  "devDependencies": {
    "esbuild": "^0.20.2",
    "stylus": "^0.62.0"
  },
  "dependencies": {
    "http-server": "^0.8.5"
  }
}
