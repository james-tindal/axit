
/* --- Testimonials section --- */

#reviews
    padding 99px 0 101px

#reviews .container
  padding 0
  @media ( min-width 1200px )
    width 1148px

#reviews h2
  letter-spacing -0.4px

#reviews p
  padding-bottom 33px

q
  display block
  border-radius 4px
  padding 21px 12px 26px
  position relative
  margin-bottom 23px

  background-color #f3f3f3
  font-size 14px
  font-style italic
  font-weight 300
  letter-spacing 0.6px
  line-height 17px

q:before
  display none
q:after
  width 0
  height 0
  position absolute
  bottom -15px
  left 27px

  border-style solid
  border-width 15px 10px 0 10px
  border-color #f3f3f3 transparent transparent transparent

  content ''

.testimonial
  padding 0 60px

.testimonial img
  border-radius 50%
  height 70px
  width 70px

  vertical-align middle
  float left
  padding-left 2px

.testimonial span
  display block

.testimonial > span
  padding 11px 0 0 88px

.name
  color #2d2d2d
  font-weight 700
  font-size 20px
  padding-bottom 1px
