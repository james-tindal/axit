
/* --- Testimonials section --- */

#reviews
  padding 100px 0

#reviews h2
  letter-spacing -0.4px

#reviews .testimonials
  display flex
  gap 20px
  overflow-x auto
  scroll-snap-type x mandatory
  scrollbar-width none
  overscroll-behavior-x contain
  scroll-behavior smooth

  &::-webkit-scrollbar
    width 0

#reviews .testimonial
  scroll-snap-align start
  pointer-events none
  user-select none

  flex 0 0 calc((100% - 2*20px) / 3)
  @media (max-width 650px)
    flex 0 0 calc((100% - 20px) / 2)

  @media (max-width 465px)
    flex 0 0 100%

#reviews .testimonial *
  pointer-events none

#reviews .testimonial img
  border-radius 50%
  height 70px
  width 70px

  float left
  padding-left 2px

#reviews .testimonial span
  display block

#reviews .testimonial > span
  padding 11px 0 0 88px

#reviews .name
  color #2d2d2d
  font-weight 700
  font-size 20px
  padding-bottom 1px

#reviews q
  display block
  border-radius 4px
  padding 21px 12px 26px
  position relative
  margin-bottom 23px

  background-color #f3f3f3
  font-size 14px
  font-style italic
  font-weight 300
  letter-spacing 0.6px
  line-height 17px

#reviews q:before
  display none
#reviews q:after
  width 0
  height 0
  position absolute
  bottom -15px
  left 27px

  border-style solid
  border-width 15px 10px 0 10px
  border-color #f3f3f3 transparent transparent transparent

  content ''

.drag-to-scroll
  cursor grab

.drag-to-scroll.dragging
  cursor grabbing
  // scroll-snap-type none !important
  // scroll-behavior auto !important
