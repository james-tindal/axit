
/* --- Feature 2 - sub list section --- */

#feature-two
  padding 100px 0 100px

#feature-two .container
  display flex
  justify-content space-between
  align-items center
  gap 60px

#feature-two img
  box-shadow 0px 20px 50px 5px #b7b7b7dd
  width 100%

#feature-two .right
  max-width 443px
  flex-shrink 0

@media (max-width 700px)
  #feature-two .shadow-img
    display none
  #feature-two .container
    justify-content right
  #feature-two .right
    flex-shrink 1

#feature-two p
  line-height 20px

#feature-two ul
  margin-top 41px

#feature-two li
  padding-left 41px
  margin-bottom 36px

#feature-two li:last-child
  margin-bottom 0

.fa-li
  height 40px
  width 40px

  border 2px solid
  border-radius: 50%
  margin-left 5px

  color $highlight
  font-size 16px

.fa-li:before
  position relative
  top 11px
