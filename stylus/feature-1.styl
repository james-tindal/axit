/* --- Feature 1 - tabs section --- */

#feature-one
  background-color #f1f1f1
  .row
    margin 146px 0 115px
  img
    float right
    margin-top 20px

[tab-selection]
  padding-left 7px

[select-tab]
  height 110px
  width 110px
  margin 1px
  padding 45px 34px 45px 35px

  cursor pointer

  background-color #2d2d2d
  color white
  font-weight 600
  font-size 15px
  text-transform uppercase
  &:first-of-type
    border-radius 3px 3px 0px 0px
  &:last-of-type
    border-radius 0px 0px 3px 3px

  transition background-color 0.8s ease-in

[select-tab].active
  background-color $highlight

[tab-page]
  position absolute
  transition:opacity 0.8s ease-in
  margin-left 17px
  margin-right 23px
  margin-top 3px
