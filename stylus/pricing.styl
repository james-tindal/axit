
/* --- Pricing Options section --- */

#pricing
  padding 100px 0
  
  background-color #f1f1f1
  text-align center

#pricing .container
  padding 0 clamp(0px, 3.5%, 30px)

#pricing p
  padding-bottom 58px

#pricing .pricing-boxes
  display flex
  align-items flex-end
  gap 3.6%

#pricing .pricing-box
  width calc(100% / 3)

@media (max-width 621px)
  #pricing .pricing-box:last-child .feature
    padding-top 7.35px
    padding-bottom 7.35px

.pricing-box *
  display block
  width 100%

.pricing-box h3
.price
small
  background-color #2d2d2d

small
  line-height 25px
  padding-bottom 15px

  letter-spacing 0.5px
  font-weight 600
  font-size 14px
  font-style italic

.pricing-box h3
  border-bottom 1px solid
  line-height 59px

  color white
  font-weight 600
  font-size clamp(0px, 4vw, 20px)

.pricing-box h3:after
  display none

.price
  padding-top 16px

  color white
  font-family $raleway
  font-weight 600
  font-size clamp(0px, 15vw, 94px)

  line-height 0.8em

.price:before
  content '$'
  font-size clamp(0px, 6vw, 35px)
  
.orange
  padding 10.5px 0
  line-height 20px

  background-color $highlight
  color white
  font-weight 600
  text-transform uppercase

  &:empty
    padding 2px 0 3px

.feature
  line-height 20px
  padding 10px 0
  border-top 1px solid #f3f3f3

  background-color white
  text-transform uppercase

.feature, .orange, small
  font-size clamp(0px, 3.2vw, 14px)
  line-height clamp(0px, 5vw, 20px)
  padding-left 3px
  padding-right 3px
