
/* --- Custom section --- */

#custom
  padding 65px 0
  background-image url('/img/custom_section.jpg')
  background-position center
  background-repeat no-repeat
  background-size cover
  color white

  h2
    color white
  h2:after
    background-color white

  .btn-white
    margin-left auto
    margin-right auto
    display block


#custom p
  specialp()
  padding 0
  opacity .6
  font-weight 400
