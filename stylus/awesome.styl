
/* --- Why This Is Awesome section --- */

#awesome
  padding 100px 0

#awesome .our-process
  display flex
  gap 28px

#awesome *
  text-align center
  margin 0 auto

#awesome h2
  letter-spacing -0.5px

#awesome h3
  padding-bottom 18px
  box-sizing content-box

@media (max-width 668px) and (min-width 600px)
  #awesome h3
    max-width 180px
    min-height 60px

@media (max-width 600px)
  #awesome .our-process
    flex-direction column
    max-width 348px
    gap 70px

#awesome h3:after
  display none

#awesome p
  line-height 20px

#awesome .fa
  border 2px solid
  border-radius: 50%
  width 70px
  height 70px
  display block

  margin-bottom 22px

  font-size 32px
  color $highlight
  
  content ''

#awesome .fa:before
  position relative
  top 16px
