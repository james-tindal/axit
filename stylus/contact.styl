
/* --- Contact section --- */

#contact
  padding 100px 0

#contact .fields
  display flex
  gap 6.1%
  margin-top 39px

  .left, .right
    width 50%
    height 154px

  @media (max-width 580px)
    flex-direction column
    gap 40px

    .left, .right
      width 100%


#contact .left
  display flex
  flex-direction column
  justify-content space-between

#contact textarea
  height 100%

#contact p
  padding-bottom 39px

#contact button
  background-color $highlight-light
  font-weight 500
  padding 11px 22px
  color white
  display block
  margin auto
  margin-top 42px

  border 0
  border-radius 3px
  box-shadow: 0.5px 0.866px 3px 0px #0005
