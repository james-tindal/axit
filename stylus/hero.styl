
section#hero
  padding-bottom 110px
  padding-top 110px

  background-image url('/img/header-bg.jpg')
  background-position center
  background-repeat no-repeat
  background-size cover
  color white

section#hero .container
  display flex
  align-items center
  justify-content space-between
  gap 20px

@media (max-width 800px)
  section#hero .container
    flex-direction column
    gap 80px

  section#hero #trial-form
    width 100%
    max-width 525px
    min-width unset


section#hero .left
  max-width 525px

section#hero .brand
  display block

  font-size 84px
  line-height 0.65

  margin-bottom 30px

#sub-heading
  font-family $raleway
  text-transform uppercase
  line-height 1.18
  font-weight 400
  font-size 36px

#sub-heading:after
  display block
  height 2px
  margin 33px 3px 35px
  width 64px

  background-color white

  content '' 

specialp()
  opacity .7
  font-family $raleway
  font-weight 300
  font-size 16px
  line-height 1.438
  margin-bottom 10px

section#hero p
  specialp()
  max-width 92%

section#hero #download-btn
  margin-top 32px
  margin-left 3px
  padding-bottom 8px


/* --- Trial Form --- */

#trial-form
  background-color white
  border-radius 8px
  margin-top 30px
  min-width 360px

#trial-form .fields
  padding 20px 38px 34px
  display flex
  flex-direction column
  justify-content space-around
  height 254px


#trial-form h3
  display block
  border-radius 4px 4px 0px 0px
  text-align center
  line-height 54px

  background-color #f3f3f3

  text-transform capitalize

#trial-form h3:after
  display none

.highlight
  text-transform uppercase
  color $highlight

#trial-form button
  border 0
  display block
  width 100%
  border-radius 0px 0px 4px 4px

  background-color $highlight-light
  font-weight 600
  line-height 54px
  color white
  font-size 15px
