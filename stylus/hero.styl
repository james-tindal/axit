
header
  height 641px
  padding-bottom 110px
  padding-top 110px

  background-image url('/img/header-bg.jpg')
  background-position center
  background-repeat no-repeat
  background-size cover
  color white

header .brand
  display block
  font-family $open-sans

  font-size 86px
  line-height 0.65

  margin-bottom 30px

#sub-heading
  font-family $raleway
  text-transform uppercase
  line-height 1.18
  letter-spacing -0.3px

#sub-heading:after
  display block
  height 2px
  margin 33px 3px 35px
  width 64px

  background-color white

  content '' 

specialp()
  color rgba(255, 255, 255, 0.6)
  font-family $raleway
  font-weight 200
  font-size 16px
  line-height 1.438
  margin-bottom 10px

header p                              
  specialp()

header p.row
  padding-left 17px

header #download-btn
  margin-top 32px
  margin-left 3px
  padding-bottom 8px


/* --- Trial Form --- */

@media ( min-width 992px )
  .trial-form-col
    padding-left 2px
    padding-right 16px

#trial-form
  background-color white
  border-radius 8px
  margin-top 30px

.form
  padding 11px 38px 10px


#trial-form h3
  display block
  border-radius 4px 4px 0px 0px
  text-align center
  line-height 54px

  background-color #f3f3f3

  text-transform capitalize

#trial-form h3:after
  display none

.highlight
  text-transform uppercase
  color $highlight

#trial-form button
  border 0
  display block
  width 100%
  border-radius 0px 0px 4px 4px

  background-color $highlight-light
  font-weight 600
  line-height 36px
