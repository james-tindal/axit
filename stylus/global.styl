$highlight-light = #ff9b51
$highlight = #ff8b38
$open-sans = 'Open Sans', Helvetica, Arial, sans-serif
$raleway = Raleway, Helvetica, Arial, sans-serif


*,
*::before,
*::after {
  box-sizing border-box
  margin 0
  padding 0
}

body
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale

  color #86878b
  font-family $open-sans
  font-weight 400
  font-size 14px
  line-height 1.4
  margin 0

.container
  max-width 1101px
  margin 0 auto
  height 100%
  padding 0 30px
  box-sizing content-box

.brand
  .ax
    font-weight 700
    color white
  .it
    font-weight 300
    color $highlight

p
  font-size 14px
  margin-bottom 1.5em

h1
  margin 0
  line-height 1.08

h2
  margin 0

  color #2d2d2d
  font-family $raleway
  font-weight 400
  font-size 36px
  text-align center
  text-transform uppercase
  line-height 1.18

h2:after
  display block
  height 2px
  margin 23px auto 26px
  width 64px

  background-color $highlight

  content ''

h2 + p
  text-align center
  padding-bottom 100px

h3
  margin 0

  color #2d2d2d
  font-family $open-sans
  font-size 20px
  font-weight 700
  line-height 1.5

h3:after
  display block
  height 2px
  margin 23px 1px 26px
  width 64px

  background-color $highlight

  content ''

h4
  margin-bottom 7px

  color #2d2d2d
  font-family $open-sans
  font-size 14px
  font-weight 700

.btn-white-border, .btn-orange
  font-family $open-sans
  font-size 15px
  margin-top 31px
  padding 9px 30px
  color white

.btn-white-border
  border 2px solid white
  background-color transparent

.btn-orange
  background-color $highlight
  font-weight 600

  border 0
  border-radius 3px
  box-shadow: 0.5px 0.866px 3px 0px #0005

input, textarea
  border none
  border-radius 0
  resize none
  width 100%

  margin 20px 0 17px
  padding 5px 12px 5px 12px
  border-bottom 1px solid #d2d2d2

  font-size 14px
  color #86878b

  &:focus
    outline none
    border-color #d2d2d2
  
  +placeholder()
    color #d2d2d2

i.fa
  transition color 0.1s ease
